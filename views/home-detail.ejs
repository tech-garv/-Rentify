<%- include('partials/head') %>

<body class="bg-gray-100 min-h-screen">

  <div class="container mx-auto px-4 py-10">


<!-- 🔙 Back Button -->
<div class="mb-6">
  <a href="/" class="inline-flex items-center gap-2 text-blue-600 font-medium hover:underline">
    ← Back to Home
  </a>
</div>

<!-- 🔥 MAIN CARD -->
<div class="max-w-3xl mx-auto bg-white rounded-2xl shadow-lg overflow-hidden">

  <!-- Image -->
  <div class="overflow-hidden">
    <img src="<%= home.image %>" 
         class="w-full h-72 object-cover hover:scale-105 transition duration-300" />
  </div>

  <!-- Content -->
  <div class="p-6">

    <!-- Title -->
    <h1 class="text-3xl font-bold mb-2">
      <%= home.houseName %>
    </h1>

    <!-- Location -->
    <p class="text-gray-600 text-lg mb-4">
      📍 <%= home.location %>
    </p>

    <!-- Price + Rating -->
    <div class="flex justify-between items-center mb-6">

      <p class="text-2xl font-bold text-red-500">
        ₹ <%= home.price %> 
        <span class="text-sm text-gray-500">/ night</span>
      </p>

      <span class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full font-semibold">
        ⭐ <%= home.rating %>
      </span>

    </div>


  </div>

</div>


  </div>

</body>
</html>
